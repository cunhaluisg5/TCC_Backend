                         "firebase-admin":  "^13.0.0",
                         "helmet":  "^8.2.0",
                         "jsonwebtoken":  "^9.0.2",
                         "nodemailer":  "^9.0.3",
                         "nodemailer-express-handlebars":  "^7.0.0",
